{{#> layout}}

  <p style="margin:0 0 20px;font-family:'Noto Sans',system-ui,sans-serif;font-size:15px;line-height:1.65;color:#1A0A12;">
    Hi there,
  </p>

  <!-- Document banner -->
  <table cellpadding="0" cellspacing="0" border="0" role="presentation" width="100%"
         style="margin:0 0 24px;">
    <tr>
      <td align="center"
          style="background:linear-gradient(135deg,#652d90 0%,#4a2168 55%,#9e77ff 100%);
                 border-radius:10px;padding:24px 28px;" bgcolor="#652d90">
        <p style="margin:0 0 6px;font-family:'Noto Sans',system-ui,sans-serif;
                  font-size:22px;font-weight:700;color:#ffffff;line-height:1.3;">
          Your {{documentTypeName}} is Ready
        </p>
        <p style="margin:0;font-family:'Noto Sans',system-ui,sans-serif;
                  font-size:14px;color:rgba(255,255,255,0.85);">
          Generated by Anna, your AI Amplify Business Assistant
        </p>
      </td>
    </tr>
  </table>

  <p style="margin:0 0 20px;font-family:'Noto Sans',system-ui,sans-serif;font-size:15px;line-height:1.65;color:#1A0A12;">
    Your <strong style="color:#652d90;">{{documentTypeName}}</strong>
    {{#if title}}for <strong>{{title}}</strong>{{/if}}
    has been generated and is attached to this email as a PDF.
  </p>

  <!-- Document details box -->
  <table cellpadding="0" cellspacing="0" border="0" role="presentation" width="100%"
         style="margin:0 0 24px;">
    <tr>
      <td style="background-color:#F1ECFA;border:1px solid #F1ECFA;border-radius:8px;padding:16px 20px;">
        <p style="margin:0 0 6px;font-family:'Noto Sans',system-ui,sans-serif;
                  font-size:13px;font-weight:600;color:#6B7280;text-transform:uppercase;letter-spacing:0.5px;">
          Document
        </p>
        <p style="margin:0;font-family:'Noto Sans',system-ui,sans-serif;
                  font-size:15px;font-weight:600;color:#1A0A12;">
          {{#if title}}{{title}}{{else}}{{documentTypeName}}{{/if}}
        </p>
      </td>
    </tr>
  </table>

  <p style="margin:0 0 20px;font-family:'Noto Sans',system-ui,sans-serif;font-size:13px;line-height:1.6;color:#6B7280;">
    Open the attached PDF to view your complete document. You can print it, share it, or use it to guide your next steps.
  </p>

  <!-- Resources CTA -->
  <table cellpadding="0" cellspacing="0" border="0" role="presentation" width="100%"
         style="margin:0 0 20px;">
    <tr>
      <td style="background-color:#F1ECFA;border-left:4px solid #652d90;border-radius:0 8px 8px 0;
                 padding:12px 16px;">
        <p style="margin:0 0 4px;font-family:'Noto Sans',system-ui,sans-serif;
                  font-size:13px;font-weight:600;color:#652d90;">
          Keep growing with AI Amplify
        </p>
        <p style="margin:0;font-family:'Noto Sans',system-ui,sans-serif;
                  font-size:13px;color:#6B7280;">
          Return to your dashboard to access AI mentors, courses, expert sessions, and partner offers — all free.
        </p>
      </td>
    </tr>
  </table>

  <table cellpadding="0" cellspacing="0" border="0" role="presentation" style="margin:0 0 20px;">
    <tr>
      <td align="center" bgcolor="#652d90"
          style="background-color:#652d90;border-radius:8px;mso-padding-alt:0;">
        <a href="{{siteUrl}}/dashboard" target="_blank"
           style="display:inline-block;padding:12px 28px;
                  font-family:'Noto Sans',system-ui,sans-serif;
                  font-size:14px;font-weight:700;color:#ffffff;
                  text-decoration:none;border-radius:8px;">
          Back to Dashboard
        </a>
      </td>
    </tr>
  </table>

{{/layout}}
