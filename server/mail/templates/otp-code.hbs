{{#> layout}}

  <p style="margin:0 0 20px;font-family:'Noto Sans',system-ui,sans-serif;font-size:15px;line-height:1.65;color:#1A0A12;">
    Use the verification code below to confirm your email and continue setting up your
    <strong style="color:#652d90;">AI Amplify</strong> account.
  </p>

  <!-- Verification code -->
  <table cellpadding="0" cellspacing="0" border="0" role="presentation" width="100%"
         style="margin:0 0 24px;">
    <tr>
      <td align="center"
          style="background:linear-gradient(135deg,#652d90 0%,#4a2168 55%,#9e77ff 100%);
                 border-radius:10px;padding:28px 28px;" bgcolor="#652d90">
        <p style="margin:0 0 8px;font-family:'Noto Sans',system-ui,sans-serif;
                  font-size:13px;font-weight:600;letter-spacing:1px;
                  text-transform:uppercase;color:rgba(255,255,255,0.85);">
          Your verification code
        </p>
        <p style="margin:0;font-family:'Noto Sans',system-ui,sans-serif;
                  font-size:40px;font-weight:700;letter-spacing:12px;
                  color:#ffffff;line-height:1.2;">
          {{code}}
        </p>
      </td>
    </tr>
  </table>

  <!-- Expiry notice -->
  <table cellpadding="0" cellspacing="0" border="0" role="presentation" width="100%"
         style="margin:0 0 20px;">
    <tr>
      <td style="background-color:#fffbeb;border-left:4px solid #f59e0b;border-radius:0 8px 8px 0;
                 padding:12px 16px;">
        <p style="margin:0;font-family:'Noto Sans',system-ui,sans-serif;
                  font-size:13px;font-weight:500;color:#92400e;">
          This code expires in <strong>10 minutes</strong>. Enter it soon to verify your email.
        </p>
      </td>
    </tr>
  </table>

  <p style="margin:0;font-family:'Noto Sans',system-ui,sans-serif;font-size:13px;
            line-height:1.6;color:#6B7280;">
    If you didn't request this code, you can safely ignore this email — no account changes will be made.
  </p>

{{/layout}}
