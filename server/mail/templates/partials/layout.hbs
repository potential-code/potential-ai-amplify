<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Noto+Sans:wght@400;500;600;700&display=swap');
    body { margin: 0; padding: 0; background-color: #F9F9FF; }
    @media only screen and (max-width: 620px) {
      .card { width: 100% !important; }
      .padded { padding-left: 24px !important; padding-right: 24px !important; }
    }
  </style>
</head>
<body style="margin:0;padding:0;background-color:#F9F9FF;">
  <table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation"
         style="background-color:#F9F9FF;padding:32px 16px;min-height:100vh;">
    <tr>
      <td align="center" valign="top">

        <table class="card" width="600" cellpadding="0" cellspacing="0" border="0" role="presentation"
               style="max-width:600px;width:100%;">

          <!-- Gradient accent strip at top -->
          <tr>
            <td height="5" style="background:linear-gradient(135deg,#652d90 0%,#4a2168 55%,#9e77ff 100%);
                font-size:0;line-height:0;border-radius:12px 12px 0 0;" bgcolor="#652d90">&nbsp;</td>
          </tr>

          <!-- Logo header -->
          <tr>
            <td align="center" bgcolor="#ffffff"
                style="background-color:#ffffff;padding:28px 40px 22px;
                       border-left:1px solid #F1ECFA;border-right:1px solid #F1ECFA;">
              <a href="{{siteUrl}}" target="_blank" style="display:inline-block;text-decoration:none;">
                <img src="{{siteUrl}}/images/redesign/potential-logo.png"
                     alt="Potential.org — AI Amplify"
                     width="180" height="75"
                     style="display:block;max-width:180px;height:auto;border:0;outline:none;text-decoration:none;">
              </a>
            </td>
          </tr>

          <!-- Header divider -->
          <tr>
            <td height="1" bgcolor="#F1ECFA"
                style="background-color:#F1ECFA;font-size:0;line-height:0;
                       border-left:1px solid #F1ECFA;border-right:1px solid #F1ECFA;">&nbsp;</td>
          </tr>

          <!-- Email body -->
          <tr>
            <td class="padded" bgcolor="#ffffff"
                style="background-color:#ffffff;padding:36px 40px 40px;
                       border-left:1px solid #F1ECFA;border-right:1px solid #F1ECFA;
                       font-family:'Noto Sans',system-ui,-apple-system,sans-serif;
                       font-size:15px;line-height:1.65;color:#1A0A12;">
              {{> @partial-block}}
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td align="center" bgcolor="#F9F9FF"
                style="background-color:#F9F9FF;padding:22px 40px 28px;
                       border:1px solid #F1ECFA;border-top:none;border-radius:0 0 12px 12px;
                       font-family:'Noto Sans',system-ui,-apple-system,sans-serif;">
              <p style="margin:0 0 4px;font-size:13px;font-weight:600;color:#1A0A12;">The AI Amplify Team</p>
              <p style="margin:0 0 2px;font-size:12px;color:#6B7280;">
                AI Amplify &mdash; Powered by Potential.org
              </p>
              <p style="margin:10px 0 0;font-size:11px;color:#9CA3AF;">
                Potential &copy; 2005-2026 | All Rights Reserved.
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
