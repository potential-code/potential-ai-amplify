<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Noto+Sans:wght@400;500;600;700&display=swap');
    body { margin: 0; padding: 0; background-color: #FDF5F9; }
    @media only screen and (max-width: 620px) {
      .card { width: 100% !important; }
      .padded { padding-left: 24px !important; padding-right: 24px !important; }
    }
  </style>
</head>
<body style="margin:0;padding:0;background-color:#FDF5F9;">
  <table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation"
         style="background-color:#FDF5F9;padding:32px 16px;min-height:100vh;">
    <tr>
      <td align="center" valign="top">

        <table class="card" width="600" cellpadding="0" cellspacing="0" border="0" role="presentation"
               style="max-width:600px;width:100%;">

          <!-- Gradient accent strip at top -->
          <tr>
            <td height="5" style="background:linear-gradient(135deg,#9f2063 0%,#7a1a4c 55%,#c42b7a 100%);
                font-size:0;line-height:0;border-radius:12px 12px 0 0;" bgcolor="#9f2063">&nbsp;</td>
          </tr>

          <!-- Logo header -->
          <tr>
            <td align="center" bgcolor="#ffffff"
                style="background-color:#ffffff;padding:28px 40px 22px;
                       border-left:1px solid #f7e8f0;border-right:1px solid #f7e8f0;">
              <a href="{{siteUrl}}" target="_blank" style="display:inline-block;text-decoration:none;">
                <img src="{{siteUrl}}/images/SMEEP-logo.png"
                     alt="SMEEP – SME Empowerment Program"
                     width="196" height="63"
                     style="display:block;max-width:196px;height:auto;border:0;outline:none;text-decoration:none;">
              </a>
            </td>
          </tr>

          <!-- Header divider -->
          <tr>
            <td height="1" bgcolor="#f7e8f0"
                style="background-color:#f7e8f0;font-size:0;line-height:0;
                       border-left:1px solid #f7e8f0;border-right:1px solid #f7e8f0;">&nbsp;</td>
          </tr>

          <!-- Email body -->
          <tr>
            <td class="padded" bgcolor="#ffffff"
                style="background-color:#ffffff;padding:36px 40px 40px;
                       border-left:1px solid #f7e8f0;border-right:1px solid #f7e8f0;
                       font-family:'Noto Sans',system-ui,-apple-system,sans-serif;
                       font-size:15px;line-height:1.65;color:#1A0A12;">
              {{> @partial-block}}
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td align="center" bgcolor="#FDF5F9"
                style="background-color:#FDF5F9;padding:22px 40px 28px;
                       border:1px solid #f7e8f0;border-top:none;border-radius:0 0 12px 12px;
                       font-family:'Noto Sans',system-ui,-apple-system,sans-serif;">
              <p style="margin:0 0 4px;font-size:13px;font-weight:600;color:#1A0A12;">The SMEEP Team</p>
              <p style="margin:0 0 2px;font-size:12px;color:#6B7280;">
                SME Empowerment Program &mdash; Powered by potential.org
              </p>
              <p style="margin:10px 0 0;font-size:11px;color:#9CA3AF;">
                &copy; 2026 SMEEP. All rights reserved.
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
