{{#> layout}}

  <p style="margin:0 0 20px;font-family:'Noto Sans',system-ui,sans-serif;font-size:15px;line-height:1.65;color:#1A0A12;">
    Hi <strong>{{name}}</strong>,
  </p>

  <p style="margin:0 0 20px;font-family:'Noto Sans',system-ui,sans-serif;font-size:15px;line-height:1.65;color:#1A0A12;">
    Thank you for applying to join <strong style="color:#9f2063;">SMEEP</strong> as a mentor.
    We've received your application and our team will review it shortly.
  </p>

  <!-- Status info box -->
  <table cellpadding="0" cellspacing="0" border="0" role="presentation" width="100%"
         style="margin:0 0 28px;">
    <tr>
      <td style="background-color:#FDF5F9;border-left:4px solid #9f2063;border-radius:0 8px 8px 0;
                 padding:16px 20px;">
        <p style="margin:0 0 4px;font-family:'Noto Sans',system-ui,sans-serif;
                  font-size:11px;font-weight:700;letter-spacing:0.08em;
                  text-transform:uppercase;color:#9f2063;">Application Status</p>
        <p style="margin:0;font-family:'Noto Sans',system-ui,sans-serif;
                  font-size:15px;font-weight:600;color:#1A0A12;">Under Review</p>
      </td>
    </tr>
  </table>

  <p style="margin:0 0 16px;font-family:'Noto Sans',system-ui,sans-serif;font-size:15px;line-height:1.65;color:#1A0A12;">
    You'll hear from us once a decision has been made. We'll be in touch by email with the outcome.
  </p>

  <p style="margin:0;font-family:'Noto Sans',system-ui,sans-serif;font-size:13px;
            line-height:1.6;color:#6B7280;">
    Have questions in the meantime? Visit us at
    <a href="{{siteUrl}}" style="color:#9f2063;text-decoration:underline;">smeep.com</a>.
  </p>

{{/layout}}
