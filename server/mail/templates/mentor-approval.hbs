{{#> layout}}

  <p style="margin:0 0 20px;font-family:'Noto Sans',system-ui,sans-serif;font-size:15px;line-height:1.65;color:#1A0A12;">
    Hi <strong>{{mentorName}}</strong>,
  </p>

  <!-- Approval banner -->
  <table cellpadding="0" cellspacing="0" border="0" role="presentation" width="100%"
         style="margin:0 0 24px;">
    <tr>
      <td align="center"
          style="background:linear-gradient(135deg,#652d90 0%,#4a2168 55%,#9e77ff 100%);
                 border-radius:10px;padding:24px 28px;" bgcolor="#652d90">
        <p style="margin:0 0 6px;font-family:'Noto Sans',system-ui,sans-serif;
                  font-size:22px;font-weight:700;color:#ffffff;line-height:1.3;">
          Application Approved!
        </p>
        <p style="margin:0;font-family:'Noto Sans',system-ui,sans-serif;
                  font-size:14px;color:rgba(255,255,255,0.85);">
          Welcome to the AI Amplify mentor community
        </p>
      </td>
    </tr>
  </table>

  <p style="margin:0 0 20px;font-family:'Noto Sans',system-ui,sans-serif;font-size:15px;line-height:1.65;color:#1A0A12;">
    Your application to join <strong style="color:#652d90;">AI Amplify</strong> as a mentor has been approved.
    We're excited to have you on board. Click the button below to set up your account and get started.
  </p>

  <!-- Setup CTA button -->
  <table cellpadding="0" cellspacing="0" border="0" role="presentation" style="margin:0 0 24px;">
    <tr>
      <td align="center" bgcolor="#652d90"
          style="background-color:#652d90;border-radius:8px;mso-padding-alt:0;">
        <a href="{{setupLink}}" target="_blank"
           style="display:inline-block;padding:14px 36px;
                  font-family:'Noto Sans',system-ui,sans-serif;
                  font-size:15px;font-weight:700;color:#ffffff;
                  text-decoration:none;border-radius:8px;
                  mso-padding-alt:14px 36px;">
          Set Up Your Account
        </a>
      </td>
    </tr>
  </table>

  <!-- Expiry notice -->
  <table cellpadding="0" cellspacing="0" border="0" role="presentation" width="100%"
         style="margin:0 0 20px;">
    <tr>
      <td style="background-color:#fffbeb;border-left:4px solid #f59e0b;border-radius:0 8px 8px 0;
                 padding:12px 16px;">
        <p style="margin:0;font-family:'Noto Sans',system-ui,sans-serif;
                  font-size:13px;font-weight:500;color:#92400e;">
          This link expires in <strong>48 hours</strong>. Please set up your account as soon as possible.
        </p>
      </td>
    </tr>
  </table>

  <p style="margin:0;font-family:'Noto Sans',system-ui,sans-serif;font-size:13px;
            line-height:1.6;color:#6B7280;">
    If you have trouble with the button above, copy and paste this URL into your browser:<br>
    <a href="{{setupLink}}" style="color:#652d90;text-decoration:underline;word-break:break-all;">{{setupLink}}</a>
  </p>

{{/layout}}
