                    {
                        "unit_id": 3575,
                        "title": "Creating Videos",
                        "slug": "creating-videos",
                        "order": 30,
                        "status": "publish",
                        "content": "",
                        "media": {
                            "youtube_video_id": "l--i_uc5bjU",
                            "banner_image_url": null,
                            "featured_image_url": null,
                            "pdf_template_url": null
                        },
                        "meta": {
                            "course-unit-read": "<h5>Videos have become the most used communication method for companies and individuals. Choose the style of video you would like to work on such as animation using vyond, or standard videos imovies. Use one of these free tools to develop a 30-second video.</h5>\r\n<h5></h5>\r\n<h5>Here are some tips to keep in mind:</h5>\r\n<div>\r\n<ul>\r\n \t<li>\r\n<h5>Capture the attention in the introduction</h5>\r\n</li>\r\n \t<li>\r\n<h5>Provide the information you want to convey</h5>\r\n</li>\r\n \t<li>\r\n<h5>Close with a call for action</h5>\r\n</li>\r\n</ul>\r\n<div align=\"center\"><button type=\"button\" class=\"btn btn-info\" data-toggle=\"collapse\" data-target=\"#demo\" aria-expanded=\"true\" style=\"\">العربية  <i class=\"fa fa-language\"></i>\r\n  </button></div>\r\n  <div id=\"demo\" class=\"collapse\">\r\n<h5 style=\"text-align: right;direction:rtl;\">– أصبحت الفيديوهات وسيلة التواصل الأكثر شيوعاً بين الشركات والأفراد. اختَر نوع الفيديو الذي يحلو لك، مثلاً الرسوم المتحرّكة بواسطة منصة vyond أو الفيديو القياسي عبر تطبيق imovies. استخدم إحدى هذه الأدوات المجانية لإعداد فيديو مدّته 30 ثانية.</h5>\r\n<h5 style=\"text-align: right;direction:rtl;\">إليك بعض النصائح المفيدة التي يجب أخذها في عين الاعتبار:</h5>\r\n<ul style=\"text-align: right;direction:rtl;\">\r\n \t<li>\r\n<h5>لفت انتباه القارئ في المقدّمة</h5>\r\n</li>\r\n \t<li>\r\n<h5>توفير المعلومات التي تودّ إيصالها</h5>\r\n</li>\r\n \t<li>\r\n<h5>إنهاء الفيديو بدعوة إلى اتّخاذ إجراء ما (أو ما يُعرف بالـCTA)</h5>\r\n</li>\r\n</ul>\r\n\r\n  </div>",
                            "course-unit-read-more": "",
                            "course-unit-quotes": "",
                            "course-unit-case-study": "<h5>Below you can see the results on when users search for the keyword \" Food Photography \":  </h5>\r\n<img src=\"https://competitions.potential.com/future-jobs/wp-content/uploads/2020/12/WhatsApp-Image-2020-12-09-at-3.05.33-PM.jpeg\" style=\"width:inherit;\">",
                            "course-unit-last-related-content": "",
                            "course-unit-customrelated": "<h5>Links to the tools mentioned:</h5>\r\n<ul>\r\n \t<li>\r\n<h5><a href=\"http://vyond.com\" target=\"_blank\" rel=\"noopener\">vyond.com</a></h5>\r\n</li>\r\n</ul>\r\n<h5> Watch the video below to learn how to make a video using Vyond:</h5>\r\n<div style=\"top: 0px; left: 0px; position: relative; width: 100%; display: block;\" id=\"fg-plyr\">\r\n        <div data-video-id=\"tR50jRU7KZc\" data-type=\"youtube\"></div>\r\n    </div>\r\n\r\n<h5> This unit  will prepare you for these kind of jobs and here are a few examples of how much you can start to earn: </h5> \r\n<div class=\"row\">\r\n<div class=\"col-md-6\">\r\n<img src=\"https://competitions.potential.com/future-jobs/wp-content/uploads/2020/12/video.png\" style=\"width: 90%;\">\r\n</div>\r\n<div class=\"col-md-6\">\r\n<img src=\"https://competitions.potential.com/future-jobs/wp-content/uploads/2020/12/vytond.png\" style=\"width: 90%;\">\r\n</div>\r\n</div>",
