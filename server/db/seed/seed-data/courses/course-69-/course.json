                                    "type": "multi",
                                    "text": "ما هي العناصر الثلاثة التي تستخدمها الشركات لقياس أداءها وفقها؟",
                                    "image": "",
                                    "hint": "",
                                    "explanation": "",
                                    "answer_type": "",
                                    "answers": [
                                        {
                                            "index": 1,
                                            "text": "الناس، الكوكب، الربح",
                                            "is_correct": true
                                        },
                                        {
                                            "index": 2,
                                            "text": "المنتج، المكان، العملية",
                                            "is_correct": false
                                        },
                                        {
                                            "index": 3,
                                            "text": "المنتج، السعر، المكان",
                                            "is_correct": false
                                        },
                                        {
                                            "index": 4,
                                            "text": "الناس، المنتج، العملية",
                                            "is_correct": false
                                        }
                                    ],
                                    "correct_answer_raw": "a:1:{i:0;s:1:\"1\";}",
                                    "question_id": 1344,
                                    "order": 0
                                },
                                {
                                    "type": "truefalse",
                                    "text": "عند دمج أشخاص من خلفيات متنوعة في مكان العمل، ينبغي على الشركات تأكيد شمولية الثقافة في المؤسسة، حيث يحظى الناس بالتقدير والاحترام والدعم. ",
                                    "image": "",
                                    "hint": "",
                                    "explanation": "",
                                    "answer_type": "",
                                    "correct_answer": "true",
                                    "question_id": 1345,
                                    "order": 1
                                },
                                {
                                    "type": "multi",
                                    "text": "عند إطلاق برنامج ابتكار مفتوح، ستقوم بما يلي:",
                                    "image": "",
                                    "hint": "",
                                    "explanation": "",
                                    "answer_type": "",
                                    "answers": [
                                        {
                                            "index": 1,
                                            "text": "الحصول على الأفكار من المجتمع، وتثقيف المجتمع حول الجوانب الرئيسية لقطاعك",
                                            "is_correct": true
                                        },
                                        {
                                            "index": 2,
                                            "text": "دفع الكثير من المال للحصول على أفكار جديدة، والمساعدة على تثبيت علامتك التجارية",
                                            "is_correct": false
                                        },
                                        {
                                            "index": 3,
                                            "text": "وضع الكثير من الجهد والوقت والمال لتحديد أهم المواهب، الحصول على الأفكار من المجتمع",
                                            "is_correct": false
                                        }
                                    ],
                                    "correct_answer_raw": "a:1:{i:0;s:1:\"1\";}",
                                    "question_id": 1346,
                                    "order": 2
                                },
                                {
                                    "type": "truefalse",
                                    "text": "يُحمّل العملاء والحكومات والمساهمين الشركاتَ مسؤولية أكبر تجاه بيئاتها المحيطة كجزء من المسؤولية الاجتماعية للشركات. ",
                                    "image": "",
                                    "hint": "",
                                    "explanation": "",
                                    "answer_type": "",
                                    "correct_answer": "true",
                                    "question_id": 1347,
                                    "order": 3
                                },
                                {
                                    "type": "truefalse",
                                    "text": "قد تكون البرامج التعليمية أدوات رائعة للمسؤولية الاجتماعية للشركات بالنسبة لعملك. فهي تساعدك على تثقيف أفراد المجتمع حول شيء مفيد بالنسبة لهم، ويكون لها تأثير إيجابي على المجتمع وذلك سيعود بالنفع على عملك أيضاً.",
                                    "image": "",
                                    "hint": "",
                                    "explanation": "",
