                    {
                        "unit_id": 2861,
                        "title": "Channel Strategies",
                        "slug": "channel-strategies-2",
                        "order": 70,
                        "status": "publish",
                        "content": "",
                        "media": {
                            "youtube_video_id": null,
                            "banner_image_url": null,
