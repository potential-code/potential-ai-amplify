                    {
                        "unit_id": 2859,
                        "title": "5 Common Customer Relationship Types",
                        "slug": "5-common-customer-relationship-types",
                        "order": 60,
                        "status": "publish",
                        "content": "",
                        "media": {
                            "youtube_video_id": null,
                            "banner_image_url": null,
