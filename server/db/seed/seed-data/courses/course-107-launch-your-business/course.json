                        },
                        "meta": {
                            "course-unit-read": "",
                            "course-unit-read-more": "",
                            "course-unit-quotes": "",
                            "course-unit-case-study": "<h5>Julie is developing an app that helps students engage better in Science, Tech, Engineering, Arts and Math (STEAM). As she starts to define her customers, she tries to focus and identify the actual users of the app who would be 10-13 year olds, but then debates whether the customers are the parents of these students or the schools in which the students studies. Julie decides to target the schools in her region as primary customers since she thinks that it could be easier to market to them.</h5>",
                            "course-unit-last-related-content": "",
                            "course-unit-customrelated": "",
                            "course-unit-page-show-game": "",
