                    {
                        "unit_id": 3417,
                        "title": "Value Proposition",
                        "slug": "value-proposition-3",
                        "order": 20,
                        "status": "publish",
                        "content": "",
                        "media": {
                            "youtube_video_id": "XvGniXyphqY",
                            "banner_image_url": null,
                            "featured_image_url": null,
                            "pdf_template_url": null
                        },
                        "meta": {
                            "course-unit-read": "<h3 data-fontsize=\"24\" data-lineheight=\"26\">What do we offer each of our client segments?</h3>\r\nOur offer is what attracts our clients. It is the value that they are willing to pay for. This value can be described as a value proposition for each customer segment. It portrays a specific bundle of products and services. A business model may consist of one or several value propositions for each of its customer segments.",
                            "course-unit-read-more": "<h3 data-fontsize=\"24\" data-lineheight=\"26\">Key questions to answer:</h3>\r\n<ol>\r\n \t<li> What do we offer the market?</li>\r\n \t<li>What is the specific bundle of products and services we offer each of our customer segments?</li>\r\n \t<li> Which customer needs does each value proposition cover?</li>\r\n \t<li>Do we offer different service levels to different customer segments?</li>\r\n</ol>",
                            "course-unit-quotes": "",
                            "course-unit-case-study": "",
                            "course-unit-last-related-content": "",
                            "course-unit-customrelated": "",
                            "course-unit-page-show-game": "",
