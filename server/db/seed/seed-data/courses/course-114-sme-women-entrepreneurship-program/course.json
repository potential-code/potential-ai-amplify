                    {
                        "unit_id": 3423,
                        "title": "Revenue Streams",
                        "slug": "revenue-streams",
                        "order": 50,
                        "status": "publish",
                        "content": "",
                        "media": {
                            "youtube_video_id": "V8EF7vlUqBI",
                            "banner_image_url": null,
                            "featured_image_url": null,
                            "pdf_template_url": null
                        },
                        "meta": {
                            "course-unit-read": "<h3 data-fontsize=\"24\" data-lineheight=\"26\">How do we earn money?</h3>\r\nOur business model’s sustainability depends on the revenues we can capture from our value creating and customer facing activities. Revenue streams come from one or several segments of clients who are willing to pay for the value they get from our offer. These revenue streams come in the form of selling, lending, licensing, commissions, transaction fees or advertising fees.",
                            "course-unit-read-more": "<div id=\"hadafiaccordianmodule\" class=\"accordian fusion-accordian hadafiaccordianmodule\">\r\n<div id=\"accordion-16047-1\" class=\"panel-group\">\r\n<div class=\"fusion-panel panel-default\">\r\n<div id=\"fd7ba40442e66b537\" class=\"panel-collapse collapse in\">\r\n<div class=\"panel-body toggle-content\">\r\n<h3 data-fontsize=\"24\" data-lineheight=\"26\">Key questions to answer:</h3>\r\n<ol>\r\n \t<li> What are our revenue streams?</li>\r\n \t<li> What are the revenue streams from each customer segment and value proposition?</li>\r\n \t<li> How much is each revenue stream’s contribution to overall revenues in terms of percentages?</li>\r\n</ol>\r\n</div>\r\n</div>\r\n</div>\r\n</div>\r\n</div>",
                            "course-unit-quotes": "",
