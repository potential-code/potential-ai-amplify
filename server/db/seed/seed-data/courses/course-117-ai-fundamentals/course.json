                    {
                        "unit_id": 4440,
                        "title": "Types of AI: Generative AI",
                        "slug": "types-of-ai-generative-ai",
                        "order": 50,
                        "status": "publish",
                        "content": "",
                        "media": {
                            "youtube_video_id": "S3M8rKgy5Dk",
                            "banner_image_url": null,
