                        "unit_id": 4436,
                        "title": "Introduction to AI",
                        "slug": "introduction-to-ai",
                        "order": 10,
                        "status": "publish",
                        "content": "",
                        "media": {
                            "youtube_video_id": "iw0vs4F3-Tg",
                            "banner_image_url": null,
                            "featured_image_url": null,
                            "pdf_template_url": null
                        },
                        "meta": {
                            "course-unit-read": "<audio controls>\r\n  <source src=\"https://educate.potential.com/wp-content/uploads/2023/09/Introduction-to-AI.mp3\" type=\"audio/mp3\">\r\n  Your browser does not support the audio element.\r\n</audio>\r\n\r\n<h5>\r\n  AI, or Artificial Intelligence, is the science of building machines that think and act like humans.\r\n</h5>\r\n\r\n<h5>\r\n  Unlike traditional software that needs explicit instructions for every scenario, AI systems learn from data and experiences, adapting over time.\r\n</h5>\r\n\r\n<h5>\r\n  From AI language models like ChatGPT to sophisticated medical diagnosis tools, it's reshaping our world.\r\n</h5>\r\n\r\n<h5>\r\n  Harness its potential, and see the blend of human intelligence with technology.\r\n</h5>\r\n",
                            "course-unit-read-more": "  <div class=\"embed-responsive embed-responsive-16by9\">\r\n    <iframe class=\"embed-responsive-item\" src=\"https://www.youtube.com/embed/uMzUB89uSxU\" allowfullscreen></iframe>\r\n  </div>",
