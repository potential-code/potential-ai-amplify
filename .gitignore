# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc
*.tsbuildinfo
.expo
.expo-shared

# Next.js
.next/
next-env.d.ts

# Playwright
test-results/
playwright-report/

# Local env files
.env
.env.*.local

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# Replit
.cache/
.local/
.worktrees/

# Downloaded course cover images — generated at seed time
client/public/images/courses/

# User-uploaded files — runtime content, not for source control
server/uploads/certificates/*
!server/uploads/certificates/.gitkeep
server/uploads/media/*
!server/uploads/media/.gitkeep

# Local superpowers docs
docs/superpowers
.claude/
# Git worktrees
.worktrees/
